<div class="bg-white dark:bg-gray-800 rounded-xl border-2 border-indigo-200 dark:border-indigo-800 shadow-sm mb-6 overflow-hidden">
  <div class="px-4 py-3 bg-indigo-50 dark:bg-indigo-900/30 border-b border-indigo-100 dark:border-indigo-900 flex items-center gap-2">
    <h2 class="text-sm font-semibold text-indigo-700 dark:text-indigo-300"><%= t(".title") %></h2>
    <span class="text-sm text-indigo-500 dark:text-indigo-400">&middot; <%= l(Date.current, format: :dashboard_full) %></span>
    <% if @today_day&.habits_with_entries.present? %>
      <% completed = @today_day.habits_with_entries.count { |hw| hw.entry&.completed? } %>
      <% total = @today_day.habits_with_entries.count %>
      <span class="ml-auto text-xs font-semibold <%= completed == total ? "text-green-600 dark:text-green-400" : "text-indigo-600 dark:text-indigo-400" %>">
        <%= t(".progress", completed: completed, total: total) %>
      </span>
    <% end %>
  </div>
  <div class="p-3 flex flex-col gap-2">
    <% if @today_day.nil? || @today_day.habits_with_entries.empty? %>
      <p class="text-sm text-gray-400 dark:text-gray-500 py-2 text-center"><%= t(".no_habits") %></p>
    <% else %>
      <% @today_day.habits_with_entries.each do |hw| %>
        <%= render "habit_row", hw: hw, date: Date.current %>
      <% end %>
    <% end %>
  </div>
</div>
