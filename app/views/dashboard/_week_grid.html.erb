<%
  habit_map = {}
  habit_order = []
  @week_days.each do |day|
    day.habits_with_entries.each do |hw|
      unless habit_map.key?(hw.habit.id)
        habit_map[hw.habit.id] = { habit: hw.habit, by_date: {} }
        habit_order << hw.habit.id
      end
      habit_map[hw.habit.id][:by_date][day.date] = hw
    end
  end
%>

<% unless habit_order.empty? %>
  <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full min-w-[480px] text-sm">
        <thead>
          <tr class="bg-gray-50 dark:bg-gray-700/50 border-b border-gray-100 dark:border-gray-700">
            <th class="text-left px-4 py-2 text-xs font-semibold text-gray-500 dark:text-gray-400 w-32 min-w-[8rem]">
              <%= t(".habit") %>
            </th>
            <% @week_days.each do |day| %>
              <% is_today = day.date == Date.current %>
              <th class="text-center px-2 py-2 text-xs font-semibold w-12 <%= is_today ? "text-indigo-600 dark:text-indigo-400" : "text-gray-500 dark:text-gray-400" %>">
                <div><%= l(day.date, format: :dashboard_abbr_day) %></div>
                <div class="font-normal <%= is_today ? "text-indigo-400 dark:text-indigo-500" : "text-gray-400 dark:text-gray-500" %>">
                  <%= l(day.date, format: :dashboard_abbr_date) %>
                </div>
                <% if is_today %>
                  <div class="mt-0.5 mx-auto w-1.5 h-1.5 rounded-full bg-indigo-500"></div>
                <% end %>
              </th>
            <% end %>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
          <% habit_order.each do |habit_id| %>
            <% row = habit_map[habit_id] %>
            <% habit = row[:habit] %>
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/30 transition-colors">
              <td class="px-4 py-3">
                <span class="text-sm font-medium text-gray-800 dark:text-gray-200 truncate block max-w-[8rem]" title="<%= habit.name %>">
                  <%= habit.name %>
                </span>
              </td>
              <% @week_days.each do |day| %>
                <% hw = row[:by_date][day.date] %>
                <% is_today = day.date == Date.current %>
                <% is_future = day.date > Date.current %>
                <td class="text-center px-2 py-3 <%= is_today ? "bg-indigo-50/50 dark:bg-indigo-900/10" : "" %>">
                  <% if is_future || hw.nil? %>
                    <span class="text-gray-300 dark:text-gray-600 text-xs select-none">—</span>
                  <% elsif hw.entry.nil? %>
                    <%= link_to new_habit_entry_path(habit, date: day.date),
                        class: "inline-flex items-center justify-center w-7 h-7 rounded-full border-2 border-dashed border-gray-300 dark:border-gray-600 hover:border-indigo-400 dark:hover:border-indigo-500 hover:bg-indigo-50 dark:hover:bg-indigo-900/20 transition-colors group",
                        title: t(".log_entry") do %>
                      <span class="w-1.5 h-1.5 rounded-full bg-gray-300 dark:bg-gray-600 group-hover:bg-indigo-400 dark:group-hover:bg-indigo-500"></span>
                    <% end %>
                  <% elsif hw.entry.completed? %>
                    <%= link_to edit_habit_entry_path(habit, hw.entry),
                        class: "inline-flex items-center justify-center w-7 h-7 rounded-full bg-green-100 dark:bg-green-900/30 hover:bg-green-200 dark:hover:bg-green-900/50 transition-colors",
                        title: t(".edit_entry") do %>
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-green-600 dark:text-green-400" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                      </svg>
                    <% end %>
                  <% else %>
                    <%= link_to edit_habit_entry_path(habit, hw.entry),
                        class: "inline-flex items-center justify-center w-7 h-7 rounded-full bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors",
                        title: t(".edit_entry") do %>
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-gray-400 dark:text-gray-500" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                      </svg>
                    <% end %>
                  <% end %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>
