<div data-controller="theme" class="flex rounded-lg border border-gray-200 dark:border-gray-600 bg-gray-100 dark:bg-gray-700/60 p-0.5 gap-0.5">
  <button data-action="click->theme#setLight"
          data-theme-target="lightBtn"
          class="px-2 py-1 rounded-md text-xs transition-colors text-gray-500" title="Light">☀</button>
  <button data-action="click->theme#setSystem"
          data-theme-target="systemBtn"
          class="px-2 py-1 rounded-md text-xs transition-colors text-gray-500" title="System">⊙</button>
  <button data-action="click->theme#setDark"
          data-theme-target="darkBtn"
          class="px-2 py-1 rounded-md text-xs transition-colors text-gray-500" title="Dark">☽</button>
</div>
