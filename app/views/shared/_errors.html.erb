<% if resource.errors.any? %>
  <div class="mb-5 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg px-4 py-3">
    <p class="text-sm font-medium text-red-800 dark:text-red-300">
      <%= pluralize(resource.errors.count, "error") %> prevented this <%= resource.class.model_name.human.downcase %> from being saved:
    </p>
    <ul class="mt-2 list-disc list-inside text-sm text-red-700 dark:text-red-400 space-y-1">
      <% resource.errors.each do |error| %>
        <li><%= error.full_message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
