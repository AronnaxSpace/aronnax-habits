<% if notice.present? %>
  <div class="max-w-3xl mx-auto px-4 pt-4">
    <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 text-green-800 dark:text-green-300 rounded-lg px-4 py-3 text-sm">
      <%= notice %>
    </div>
  </div>
<% end %>

<% if alert.present? %>
  <div class="max-w-3xl mx-auto px-4 pt-4">
    <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-800 dark:text-red-300 rounded-lg px-4 py-3 text-sm">
      <%= alert %>
    </div>
  </div>
<% end %>
