<div class="flex rounded-lg border border-gray-200 dark:border-gray-600 bg-gray-100 dark:bg-gray-700/60 p-0.5 gap-0.5">
  <%= button_to "EN", locale_path, params: { locale: "en" }, method: :patch,
      class: "px-2 py-1 rounded-md text-xs transition-colors #{I18n.locale == :en ? 'bg-white dark:bg-gray-600 shadow-sm text-indigo-600 dark:text-indigo-400' : 'text-gray-500'}" %>
  <%= button_to "УК", locale_path, params: { locale: "uk" }, method: :patch,
      class: "px-2 py-1 rounded-md text-xs transition-colors #{I18n.locale == :uk ? 'bg-white dark:bg-gray-600 shadow-sm text-indigo-600 dark:text-indigo-400' : 'text-gray-500'}" %>
</div>
