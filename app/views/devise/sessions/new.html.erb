<div class="max-w-md mx-auto bg-white dark:bg-gray-800 rounded-2xl shadow-md p-8">
  <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6"><%= t(".title") %></h2>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    <div class="mb-4">
      <%= f.label :email, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <div class="mb-4">
      <%= f.label :password, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.password_field :password, autocomplete: "current-password", class: "w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="mb-5 flex items-center gap-2">
        <%= f.check_box :remember_me, class: "rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" %>
        <%= f.label :remember_me, class: "text-sm text-gray-600 dark:text-gray-400" %>
      </div>
    <% end %>

    <div>
      <%= f.submit t(".submit"), class: "w-full bg-indigo-600 text-white text-sm font-medium px-5 py-2 rounded-lg hover:bg-indigo-700 cursor-pointer" %>
    </div>
  <% end %>

  <div class="my-5 flex items-center gap-3">
    <hr class="flex-1 border-gray-200 dark:border-gray-700">
    <span class="text-xs text-gray-400 dark:text-gray-500">or</span>
    <hr class="flex-1 border-gray-200 dark:border-gray-700">
  </div>

  <%= button_to omniauth_authorize_path(:user, :aronnax),
        class: "w-full flex items-center justify-center border border-gray-300 dark:border-gray-600 text-sm font-medium text-gray-700 dark:text-gray-300 px-5 py-2 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 cursor-pointer",
        data: { turbo: false } do %>
    <%= t("devise.shared.links.sign_in_with", provider: "Aronnax") %>
  <% end %>

  <%= render "devise/shared/links" %>
</div>
