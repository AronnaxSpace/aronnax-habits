<div class="mt-5 flex flex-col items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
  <%- if controller_name != 'sessions' %>
    <p><%= link_to t(".log_in"), new_session_path(resource_name), class: "text-indigo-600 hover:text-indigo-800" %></p>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <p><%= link_to t(".sign_up"), new_registration_path(resource_name), class: "text-indigo-600 hover:text-indigo-800" %></p>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <p><%= link_to t(".forgot_password"), new_password_path(resource_name), class: "hover:text-gray-700 dark:hover:text-gray-300" %></p>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <p><%= link_to t(".no_confirmation"), new_confirmation_path(resource_name), class: "hover:text-gray-700 dark:hover:text-gray-300" %></p>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <p><%= link_to t(".no_unlock"), new_unlock_path(resource_name), class: "hover:text-gray-700 dark:hover:text-gray-300" %></p>
  <% end %>

  <%- if devise_mapping.omniauthable? && controller_name != "sessions" %>
    <%- resource_class.omniauth_providers.each do |provider| %>
      <p><%= button_to t(".sign_in_with", provider: OmniAuth::Utils.camelize(provider)), omniauth_authorize_path(resource_name, provider), data: { turbo: false } %></p>
    <% end %>
  <% end %>
</div>
