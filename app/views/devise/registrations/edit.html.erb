<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= t(".title") %></h1>
</div>

<div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 p-6 mb-6">
  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="mb-4">
      <%= f.label :email, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
      <p class="mb-4 text-sm text-gray-500 dark:text-gray-400"><%= t(".pending_reconfirmation", email: resource.unconfirmed_email) %></p>
    <% end %>

    <div class="mb-4">
      <div class="flex items-baseline gap-2 mb-1">
        <%= f.label :password, class: "text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <span class="text-xs text-gray-400 dark:text-gray-500"><%= t(".leave_blank_password") %></span>
      </div>
      <% if @minimum_password_length %>
        <p class="text-xs text-gray-400 dark:text-gray-500 mb-1"><%= t(".characters_minimum", count: @minimum_password_length) %></p>
      <% end %>
      <%= f.password_field :password, autocomplete: "new-password", class: "w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <div class="mb-4">
      <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <div class="mb-6">
      <div class="flex items-baseline gap-2 mb-1">
        <%= f.label :current_password, class: "text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <span class="text-xs text-gray-400 dark:text-gray-500"><%= t(".current_password_hint") %></span>
      </div>
      <%= f.password_field :current_password, autocomplete: "current-password", class: "w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <div>
      <%= f.submit t(".submit"), class: "bg-indigo-600 text-white text-sm font-medium px-5 py-2 rounded-lg hover:bg-indigo-700 cursor-pointer" %>
    </div>
  <% end %>
</div>

<div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-red-100 dark:border-red-900 p-6">
  <h3 class="text-base font-semibold text-red-700 dark:text-red-400 mb-2"><%= t(".danger_zone") %></h3>
  <p class="text-sm text-gray-500 dark:text-gray-400 mb-4"><%= t(".delete_description") %></p>
  <%= button_to t(".delete_account"), registration_path(resource_name), data: { turbo_confirm: t(".delete_confirm") }, method: :delete, class: "bg-white dark:bg-gray-700 text-red-600 border border-red-200 dark:border-red-900 text-sm font-medium px-4 py-2 rounded-lg hover:bg-red-50 dark:hover:bg-red-900/20 cursor-pointer" %>
</div>
