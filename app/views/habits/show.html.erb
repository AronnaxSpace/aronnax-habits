<% content_for :title, @habit.name %>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
  <h1 class="text-2xl font-bold text-gray-900"><%= @habit.name %></h1>
  <% if @habit.description.present? %>
    <p class="mt-3 text-gray-600"><%= @habit.description %></p>
  <% end %>

  <div class="mt-4 flex flex-wrap items-center gap-4 text-sm text-gray-500">
    <span class="font-medium text-gray-700"><%= @habit.frequency_label %></span>
    <span><%= @habit.start_date.strftime("%b %-d, %Y") %></span>
    <% if @habit.end_date.present? %>
      <span>→</span>
      <span><%= @habit.end_date.strftime("%b %-d, %Y") %></span>
    <% end %>
  </div>

  <div class="mt-6 pt-4 border-t border-gray-100 flex items-center gap-3">
    <%= link_to "Edit", edit_habit_path(@habit), class: "bg-white text-indigo-600 border border-indigo-200 text-sm font-medium px-4 py-2 rounded-lg hover:bg-indigo-50" %>
    <%= button_to "Delete", @habit, method: :delete, class: "bg-white text-red-600 border border-red-200 text-sm font-medium px-4 py-2 rounded-lg hover:bg-red-50 cursor-pointer", data: { turbo_confirm: "Delete this habit?" } %>
    <%= link_to "Back to habits", habits_path, class: "ml-auto text-sm text-gray-500 hover:text-gray-700" %>
  </div>
</div>
