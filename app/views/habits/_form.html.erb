<%= form_with(model: habit) do |form| %>
  <%= render "shared/errors", resource: habit %>

  <div class="mb-4">
    <%= form.label :name, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= form.text_field :name, class: "w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
  </div>

  <div class="mb-4">
    <%= form.label :description, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= form.textarea :description, rows: 4, class: "w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
  </div>

  <div class="mb-4">
    <%= form.label :frequency, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= form.select :frequency,
        Habit.frequencies.keys.map { |frequency|
          [Habit.human_enum_name(:frequency, frequency), frequency]
        },
        {},
        class: "w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
  </div>

  <div class="grid grid-cols-2 gap-4 mb-6">
    <div>
      <%= form.label :start_date, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= form.date_field :start_date, class: "w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>
    <div>
      <div class="flex items-baseline gap-1 mb-1">
        <%= form.label :end_date, class: "text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <span class="text-xs text-gray-400 dark:text-gray-500">optional</span>
      </div>
      <%= form.date_field :end_date, class: "w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>
  </div>

  <div>
    <%= form.submit class: "bg-indigo-600 text-white text-sm font-medium px-5 py-2 rounded-lg hover:bg-indigo-700 cursor-pointer" %>
  </div>
<% end %>
