<%= form_with(model: habit) do |form| %>
  <% if habit.errors.any? %>
    <div class="mb-5 bg-red-50 border border-red-200 rounded-lg px-4 py-3">
      <p class="text-sm font-medium text-red-800">
        <%= pluralize(habit.errors.count, "error") %> prevented this habit from being saved:
      </p>
      <ul class="mt-2 list-disc list-inside text-sm text-red-700 space-y-1">
        <% habit.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4">
    <%= form.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :name, class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
  </div>

  <div class="mb-6">
    <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.textarea :description, rows: 4, class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
  </div>

  <div>
    <%= form.submit class: "bg-indigo-600 text-white text-sm font-medium px-5 py-2 rounded-lg hover:bg-indigo-700 cursor-pointer" %>
  </div>
<% end %>
