<% content_for :title, t(".title") %>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= t(".title") %></h1>
  <div class="flex gap-3 mt-1 text-sm text-gray-500 dark:text-gray-400">
    <%= link_to t(".view_habit"), habit, class: "hover:text-gray-700 dark:hover:text-gray-300" %>
    <span>·</span>
    <%= link_to t(".back"), habits_path, class: "hover:text-gray-700 dark:hover:text-gray-300" %>
  </div>
</div>

<div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 p-6">
  <%= render "form", habit: habit %>
</div>
