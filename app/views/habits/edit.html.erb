<% content_for :title, "Edit Habit" %>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Edit Habit</h1>
  <div class="flex gap-3 mt-1 text-sm text-gray-500">
    <%= link_to "View habit", @habit, class: "hover:text-gray-700" %>
    <span>·</span>
    <%= link_to "Back to habits", habits_path, class: "hover:text-gray-700" %>
  </div>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
  <%= render "form", habit: @habit %>
</div>
