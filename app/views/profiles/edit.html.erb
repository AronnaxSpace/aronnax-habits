<% content_for :title, t(".title") %>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= t(".title") %></h1>
  <%= link_to t(".back"), profile_path, class: "text-sm text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 mt-1 inline-block" %>
</div>

<div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 p-6 mb-6">
  <%= render "form", profile: profile %>
</div>

<div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-red-100 dark:border-red-900 p-6">
  <h3 class="text-base font-semibold text-red-700 dark:text-red-400 mb-2"><%= t(".danger_zone") %></h3>
  <p class="text-sm text-gray-500 dark:text-gray-400 mb-4"><%= t(".delete_description") %></p>
  <%= button_to t(".delete_account"), profile_path, data: { turbo_confirm: t(".delete_confirm") }, method: :delete, class: "bg-white dark:bg-gray-700 text-red-600 border border-red-200 dark:border-red-900 text-sm font-medium px-4 py-2 rounded-lg hover:bg-red-50 dark:hover:bg-red-900/20 cursor-pointer" %>
</div>
