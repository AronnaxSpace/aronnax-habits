<% content_for :title, t(".title") %>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= t(".title") %></h1>
</div>

<div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 p-6">
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="text-lg font-semibold text-gray-900 dark:text-gray-100">@<%= profile.nickname %></p>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1"><%= Profile.human_enum_name(:language, profile.language) %></p>
    </div>
    <%= link_to t(".edit"), edit_profile_path, class: "shrink-0 bg-white dark:bg-gray-700 text-indigo-600 border border-indigo-200 dark:border-indigo-800 text-sm font-medium px-4 py-2 rounded-lg hover:bg-indigo-50 dark:hover:bg-indigo-900/30" %>
  </div>
</div>
