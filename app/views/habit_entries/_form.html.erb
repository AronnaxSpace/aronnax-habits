<% url = entry.new_record? ? habit_entries_path(@habit) : habit_entry_path(@habit, entry) %>
<%= form_with(model: entry, url: url) do |form| %>
  <% if entry.errors.any? %>
    <div class="mb-5 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg px-4 py-3">
      <p class="text-sm font-medium text-red-800 dark:text-red-300">
        <%= pluralize(entry.errors.count, "error") %> prevented this entry from being saved:
      </p>
      <ul class="mt-2 list-disc list-inside text-sm text-red-700 dark:text-red-400 space-y-1">
        <% entry.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form.hidden_field :date %>

  <div class="mb-5 flex items-center gap-3">
    <%= form.check_box :completed, class: "w-4 h-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" %>
    <%= form.label :completed, class: "text-sm font-medium text-gray-700 dark:text-gray-300" %>
  </div>

  <div class="mb-6">
    <%= form.label :note, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <span class="text-xs text-gray-400 dark:text-gray-500 block mb-1">optional</span>
    <%= form.textarea :note, rows: 3, class: "w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
  </div>

  <div class="flex items-center gap-3">
    <%= form.submit class: "bg-indigo-600 text-white text-sm font-medium px-5 py-2 rounded-lg hover:bg-indigo-700 cursor-pointer" %>
    <%= link_to "Back to dashboard", root_path(week: entry.date&.beginning_of_week(:sunday)),
        class: "text-sm text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300" %>
  </div>
<% end %>
