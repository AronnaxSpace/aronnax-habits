<% url = entry.new_record? ? habit_entries_path(habit) : habit_entry_path(habit, entry) %>
<%= form_with(model: entry, url: url, data: { turbo: false }) do |form| %>
  <%= render "shared/errors", resource: entry %>

  <%= form.hidden_field :date %>

  <div class="mb-6">
    <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-3"><%= t(".completed_label") %></p>
    <div class="flex gap-3">
      <div class="flex-1">
        <%= form.radio_button :completed, true, class: "sr-only peer" %>
        <%= form.label "completed_true", class: "flex items-center justify-center gap-2 w-full px-4 py-3 rounded-lg border-2 cursor-pointer transition-colors border-gray-200 dark:border-gray-600 text-gray-500 dark:text-gray-400 hover:border-gray-300 dark:hover:border-gray-500 peer-checked:border-green-500 peer-checked:bg-green-50 peer-checked:text-green-700 dark:peer-checked:border-green-600 dark:peer-checked:bg-green-900/20 dark:peer-checked:text-green-400" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          <span class="text-sm font-medium"><%= t(".yes") %></span>
        <% end %>
      </div>
      <div class="flex-1">
        <%= form.radio_button :completed, false, class: "sr-only peer" %>
        <%= form.label "completed_false", class: "flex items-center justify-center gap-2 w-full px-4 py-3 rounded-lg border-2 cursor-pointer transition-colors border-gray-200 dark:border-gray-600 text-gray-500 dark:text-gray-400 hover:border-gray-300 dark:hover:border-gray-500 peer-checked:border-red-400 peer-checked:bg-red-50 peer-checked:text-red-700 dark:peer-checked:border-red-500 dark:peer-checked:bg-red-900/20 dark:peer-checked:text-red-400" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
          <span class="text-sm font-medium"><%= t(".no") %></span>
        <% end %>
      </div>
    </div>
  </div>

  <div class="mb-6">
    <%= form.label :note, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <span class="text-xs text-gray-400 dark:text-gray-500 block mb-1"><%= t(".optional") %></span>
    <%= form.textarea :note, rows: 3, class: "w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
  </div>

  <div class="flex items-center gap-3">
    <%= form.submit class: "bg-indigo-600 text-white text-sm font-medium px-5 py-2 rounded-lg hover:bg-indigo-700 cursor-pointer" %>
    <%= link_to t(".back_to_dashboard"), root_path(week: entry.date&.beginning_of_week(:sunday)),
        class: "text-sm text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300" %>
  </div>
<% end %>
