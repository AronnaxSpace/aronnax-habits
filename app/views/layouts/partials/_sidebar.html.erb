<aside data-drawer-target="sidebar"
       class="fixed top-0 left-0 h-full w-64 bg-white dark:bg-gray-800 border-r border-gray-200 dark:border-gray-700 flex flex-col z-40 transition-transform duration-200 -translate-x-full md:translate-x-0">
  <div class="px-5 py-5 border-b border-gray-100 dark:border-gray-700">
    <%= link_to t("app_name"), authenticated_root_path, class: "text-lg font-semibold text-indigo-600 hover:text-indigo-800" %>
  </div>

  <nav class="flex-1 px-3 py-4 space-y-1">
    <%= link_to authenticated_root_path, data: { action: "click->drawer#close" },
        class: "flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-indigo-50 dark:hover:bg-indigo-900/40 hover:text-indigo-700 dark:hover:text-indigo-300" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
      </svg>
      <%= t(".dashboard") %>
    <% end %>
    <%= link_to habits_path, data: { action: "click->drawer#close" },
        class: "flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-indigo-50 dark:hover:bg-indigo-900/40 hover:text-indigo-700 dark:hover:text-indigo-300" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
      </svg>
      <%= t(".my_habits") %>
    <% end %>
    <%= link_to profile_path, data: { action: "click->drawer#close" },
        class: "flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-indigo-50 dark:hover:bg-indigo-900/40 hover:text-indigo-700 dark:hover:text-indigo-300" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
      </svg>
      <%= t(".profile") %>
    <% end %>
  </nav>

  <div class="px-4 py-4 border-t border-gray-100 dark:border-gray-700 space-y-3">
    <div class="flex">
      <div class="flex rounded-lg border border-gray-200 dark:border-gray-600 bg-gray-100 dark:bg-gray-700/60 p-0.5 gap-0.5">
        <button data-action="click->theme#setLight"
                data-theme-target="lightBtn"
                class="px-2 py-1 rounded-md text-xs transition-colors text-gray-500" title="Light">☀</button>
        <button data-action="click->theme#setSystem"
                data-theme-target="systemBtn"
                class="px-2 py-1 rounded-md text-xs transition-colors text-gray-500" title="System">⊙</button>
        <button data-action="click->theme#setDark"
                data-theme-target="darkBtn"
                class="px-2 py-1 rounded-md text-xs transition-colors text-gray-500" title="Dark">☽</button>
      </div>
    </div>
    <p class="text-xs text-gray-400 dark:text-gray-500 truncate"><%= current_user.email %></p>
    <%= link_to t(".account_settings"), edit_user_registration_path,
        data: { action: "click->drawer#close" },
        class: "block text-sm text-gray-600 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400" %>
    <%= button_to t(".sign_out"), destroy_user_session_path, method: :delete,
        class: "text-sm text-gray-600 dark:text-gray-400 hover:text-red-600 dark:hover:text-red-400 cursor-pointer bg-transparent border-none p-0 w-full text-left" %>
  </div>
</aside>
