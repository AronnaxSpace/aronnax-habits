<% content_for :title, t(".title") %>

<div class="min-h-screen flex items-center justify-center px-4 -mt-26 -mb-8">
  <div class="text-center max-w-md">
    <h1 class="text-4xl font-bold text-gray-900 dark:text-gray-100 mb-3"><%= t("app_name") %></h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8"><%= t(".tagline") %></p>
    <div class="flex items-center justify-center gap-3">
      <%= button_to omniauth_authorize_path(:user, :aronnax),
            class: "bg-indigo-600 text-white text-sm font-medium px-5 py-2.5 rounded-lg hover:bg-indigo-700 cursor-pointer",
            data: { turbo: false } do %>
        <%= t("devise.shared.links.sign_in_with", provider: "Aronnax") %>
      <% end %>
    </div>
  </div>
</div>
