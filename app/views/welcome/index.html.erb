      <%= link_to "Log in", new_user_session_path, class: "bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600 text-sm font-medium px-5 py-2.5 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700" %>
